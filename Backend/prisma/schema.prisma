// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  participant
  judge
  organizer
  admin
}

enum EventStatus {
  draft
  open
  active
  judging
  closed
}

enum MemberRole {
  leader
  member
}

enum RegistrationStatus {
  pending
  confirmed
  cancelled
  waitlisted
}

enum ProjectStatus {
  draft
  submitted
  under_review
  scored
}

enum AnnouncementPriority {
  info
  warning
  urgent
}

enum AnnouncementTarget {
  all
  participants
  judges
  organizers
}


model User {
  id String @id @default(uuid())

  email        String @unique
  passwordHash String @map("password_hash")

  fullName String @map("full_name")
  username String @unique

  avatarUrl   String? @map("avatar_url")
  githubUrl   String? @map("github_url")
  linkedinUrl String? @map("linkedin_url")
  bio         String?


  role UserRole @default(participant)

  isVerified Boolean @default(false) @map("is_verified")
  isActive   Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lastLoginAt DateTime? @map("last_login_at")

  organizedEvents Event[] @relation("EventOrganizer")

  ledTeams         Team[]         @relation("TeamLeader")
  teamMemberships  TeamMember[]
  registrations    Registration[]
  scores           Score[]
  judgeAssignments EventJudge[]   @relation("JudgeAssignments")
  assignedJudges   EventJudge[]   @relation("AssignedByOrganizer")

  announcementsAuthored Announcement[]     @relation("AnnouncementAuthor")
  announcementReads     AnnouncementRead[]
  refreshTokens         RefreshToken[]

  @@map("users")
}


model Event {
  id String @id @default(uuid())

  slug        String @unique
  title       String
  description String

  bannerUrl String? @map("banner_url")

  organizerId String @map("organizer_id")

  status EventStatus @default(draft)

  maxTeamSize Int @default(4) @map("max_team_size")
  minTeamSize Int @default(1) @map("min_team_size")

  maxRegistrations Int? @map("max_registrations")

  registrationOpen  DateTime @map("registration_open")
  registrationClose DateTime @map("registration_close")

  eventStart DateTime @map("event_start")
  eventEnd   DateTime @map("event_end")

  submissionDeadline DateTime @map("submission_deadline")

  timezone String

  prizePool Json @map("prize_pool")

  tags String[]

  isPublic Boolean @default(true) @map("is_public")
  isLeaderboardPublished Boolean @default(false) @map("is_leaderboard_published")


  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")


  organizer User @relation("EventOrganizer", fields: [organizerId], references: [id])

  teams         Team[]
  registrations Registration[]
  projects      Project[]
  judges        EventJudge[]

  announcements Announcement[]

  @@index([tags])
  @@map("events")
}

model Team {
  id String @id @default(uuid())

  eventId String @map("event_id")

  name       String
  inviteCode String @unique @map("invite_code")

  leaderId String @map("leader_id")

  track String?

  isOpen Boolean @default(true) @map("is_open")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id])

  leader User @relation("TeamLeader", fields: [leaderId], references: [id])

  members       TeamMember[]
  registrations Registration[]
  projects      Project[]

  @@unique([eventId, name])
  @@map("teams")
}


model TeamMember {
  teamId String @map("team_id")
  userId String @map("user_id")

  role MemberRole

  joinedAt DateTime @default(now()) @map("joined_at")

  team Team @relation(fields: [teamId], references: [id])

  user User @relation(fields: [userId], references: [id])

  @@id([teamId, userId])
  @@map("team_members")
}


model Registration {
  id String @id @default(uuid())

  eventId String @map("event_id")
  userId  String @map("user_id")

  teamId String? @map("team_id")

  status RegistrationStatus @default(pending)

  registrationData Json @map("registration_data")

  registeredAt DateTime @default(now()) @map("registered_at")

  confirmedAt DateTime? @map("confirmed_at")

  cancelledAt DateTime? @map("cancelled_at")

  event Event @relation(fields: [eventId], references: [id])

  user User @relation(fields: [userId], references: [id])

  team Team? @relation(fields: [teamId], references: [id])

  @@unique([eventId, userId])
  @@map("registrations")
}


model Project {
  id String @id @default(uuid())

  eventId String @map("event_id")
  teamId  String @map("team_id")

  title String

  description String

  techStack String[] @map("tech_stack")

  demoUrl  String? @map("demo_url")
  repoUrl  String? @map("repo_url")
  deckUrl  String? @map("deck_url")
  videoUrl String? @map("video_url")

  status ProjectStatus @default(draft)

  submittedAt DateTime? @map("submitted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id])

  team Team @relation(fields: [teamId], references: [id])

  scores Score[]

  @@unique([eventId, teamId])
  @@map("projects")
}


model Score {
  id String @id @default(uuid())

  projectId String @map("project_id")
  judgeId   String @map("judge_id")

  innovation   Int
  technical    Int
  impact       Int
  presentation Int

  total Float

  comments String?

  submittedAt DateTime @default(now()) @map("submitted_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])
  judge   User    @relation(fields: [judgeId], references: [id])

  @@unique([projectId, judgeId])
  @@map("scores")
}


model EventJudge {
  id String @id @default(uuid())

  eventId String @map("event_id")
  judgeId String @map("judge_id")

  track String?

  assignedAt DateTime @default(now()) @map("assigned_at")

  assignedBy String @map("assigned_by")

  event Event @relation(fields: [eventId], references: [id])

  judge User @relation("JudgeAssignments", fields: [judgeId], references: [id])

  organizer User @relation("AssignedByOrganizer", fields: [assignedBy], references: [id])

  @@unique([eventId, judgeId])
  @@map("event_judges")
}

model Announcement {
  id String @id @default(uuid())

  eventId String @map("event_id")

  authorId String @map("author_id")

  title String

  body String

  priority AnnouncementPriority @default(info)

  target AnnouncementTarget @default(all)

  isPublished Boolean @default(false) @map("is_published")

  publishedAt DateTime? @map("published_at")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id])

  author User @relation("AnnouncementAuthor", fields: [authorId], references: [id])

  reads AnnouncementRead[]

  @@map("announcements")
}

model AnnouncementRead {
  announcementId String @map("announcement_id")

  userId String @map("user_id")

  readAt DateTime @default(now()) @map("read_at")

  announcement Announcement @relation(fields: [announcementId], references: [id])

  user User @relation(fields: [userId], references: [id])

  @@id([announcementId, userId])
  @@map("announcement_reads")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

